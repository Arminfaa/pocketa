# Local — call Express directly (no Vercel rewrite)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production (Vercel)
# Leave NEXT_PUBLIC_API_URL unset (or empty) so the browser calls same-origin /api/*
# which Next rewrites to Render. This keeps auth cookies first-party on mobile.
# NEXT_PUBLIC_API_URL=
# API_PROXY_TARGET=https://pocketa.onrender.com

# Mail relay (Vercel serverless → host SMTP). Required in production when Render Free blocks SMTP.
# MAIL_RELAY_SECRET must match the same value on Render.
MAIL_RELAY_SECRET=
SMTP_HOST=nphost2.unitedhost.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pocketa@arminfatehi.ir
SMTP_PASS=
MAIL_FROM=pocketa@arminfatehi.ir
