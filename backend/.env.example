PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/pocketa
JWT_SECRET=change_this_jwt_secret_please
REFRESH_TOKEN_SECRET=change_this_refresh_secret_please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Local: http://localhost:3000
# Production: https://your-app.vercel.app  (چند origin با کاما جدا کنید)
CORS_ORIGIN=http://localhost:3000

# Local: false | Production (HTTPS): true
COOKIE_SECURE=false
# First-party via Vercel /api rewrite: lax (recommended for iOS PWA).
# Only use none if the browser calls the API on another site (needs Secure).
COOKIE_SAMESITE=lax
NODE_ENV=development

# Web Push (اختیاری — یادآوری بدهی)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# GoldAPI (اختیاری — قیمت طلا؛ روزانه یک‌بار در DB ذخیره می‌شود)
# https://www.goldapi.io
GOLD_API_KEY=

# Navasan (اختیاری — دلار آزاد / تتر؛ روزانه حدود ۱۴:۰۰ تهران در DB)
# http://api.navasan.tech
NAVASAN_API_KEY=

# Frontend URL for password-reset links (defaults to first CORS_ORIGIN)
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
APP_URL=http://localhost:3000

# SMTP — password reset emails (cPanel / Mihan host)
SMTP_HOST=nphost2.unitedhost.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pocketa@arminfatehi.ir
SMTP_PASS=
MAIL_FROM=pocketa@arminfatehi.ir

# Production (Render Free): HTTPS mail relay on Vercel (SMTP ports blocked on Render)
# MAIL_RELAY_URL=https://getpocketa.vercel.app/mail-relay/send
# MAIL_RELAY_SECRET=generate_a_long_random_string
MAIL_RELAY_URL=
MAIL_RELAY_SECRET=
